# ============================================
# PhantomAI Backend - Environment Variables
# ============================================

# --- REQUIRED ---
ANTHROPIC_API_KEY=

OPENAI_API_KEY=

GEMINI_API_KEY=

COHERE_API_KEY= 

MISTRAL_API_KEY=

GROQ_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434 

OLLAMA_MODEL=llama3
#GROQ_API_KEY=
# --- OPTIONAL (enables more tools) ---
SHODAN_API_KEY=

VIRUSTOTAL_API_KEY=

# --- Server Config ---
APP_NAME=PhantomAI
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cache (seconds) ---
CACHE_TTL=300

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
